---
/**
 * ViteUnDevis Widget — Injecté en marque blanche
 * Ce composant charge le widget ViteUnDevis avec le keyword de la page
 */
interface Props {
  keyword?: string;
  partnerId?: string;
  boxId?: string;
}

import { siteConfig } from '../../site.config';

const {
  keyword = siteConfig.niche.name,
  partnerId = siteConfig.viteundevis.partnerId,
  boxId = siteConfig.viteundevis.boxId,
} = Astro.props;

const encodedKeyword = encodeURIComponent(keyword);
const widgetSrc = `//www.viteundevis.com/marqueblanche/?b=${boxId}&p=${partnerId}&c=${encodedKeyword}`;
const containerId = `v${boxId}d`;
---

<div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden">
  <!-- Header -->
  <div class="bg-gradient-to-r from-dark to-brand-800 px-6 py-5 text-white">
    <h3 class="text-xl font-bold">
      Devis {siteConfig.niche.nameShort} Gratuit
    </h3>
    <p class="text-brand-200 text-sm mt-1">Sans engagement • Réponse sous 48h</p>
  </div>

  <!-- Widget Container -->
  <div class="p-4 sm:p-6">
    <div id={containerId} class="min-h-[400px] w-full"></div>

    <!-- Trust Indicators -->
    <div class="mt-6 pt-5 border-t border-gray-100">
      <div class="grid grid-cols-3 gap-4 text-center">
        <div class="flex flex-col items-center">
          <span class="text-green-500 text-xl mb-1">🛡️</span>
          <span class="text-xs text-gray-600 font-medium">100% Gratuit</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="text-green-500 text-xl mb-1">✅</span>
          <span class="text-xs text-gray-600 font-medium">Sans engagement</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="text-green-500 text-xl mb-1">⚡</span>
          <span class="text-xs text-gray-600 font-medium">Réponse 48h</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Load jQuery (required by ViteUnDevis) then widget -->
<script is:inline define:vars={{ widgetSrc, containerId, boxId, partnerId, encodedKeyword }}>
  function loadVUDWidget() {
    var target = document.getElementById(containerId);
    if (!target || target.dataset.loaded === 'true') return;
    target.dataset.loaded = 'true';

    var s = document.createElement('script');
    s.type = 'text/javascript';
    s.src = widgetSrc;
    s.async = true;
    document.body.appendChild(s);
  }

  function initWidget() {
    if (window.jQuery) {
      loadVUDWidget();
    } else {
      var jq = document.createElement('script');
      jq.src = 'https://ajax.googleapis.com/ajax/libs/jquery/2.2.4/jquery.min.js';
      jq.onload = loadVUDWidget;
      document.head.appendChild(jq);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWidget);
  } else {
    initWidget();
  }
</script>
