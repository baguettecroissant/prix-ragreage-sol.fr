---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteWidget from '../components/QuoteWidget.astro';
import PriceTable from '../components/PriceTable.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FAQ from '../components/FAQ.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { siteConfig } from '../../site.config';
import { getAllCities, getCityBySlug, getNearbyCities } from '../lib/cities';
import { blogArticles } from '../data/blog-articles';
import localContentRaw from '../data/local-content.json';

const localContent = localContentRaw as Record<string, {
  intro: string;
  expert_advice: string;
  real_estate_context: string;
  authority_link_html: string;
  faq_local: { question: string; answer: string };
  market_data: string;
}>;

export function getStaticPaths() {
  const allCities = getAllCities();
  return allCities.map(city => ({
    params: { city: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;
const nearbyCities = getNearbyCities(city, 8);
const lc = localContent[city.slug];

// SEO
const title = siteConfig.niche.seoTitleTemplate
  .replace('{city}', city.name)
  .replace('{zip}', city.zip);
const description = siteConfig.niche.metaDescTemplate
  .replace('{city}', city.name)
  .replace('{zip}', city.zip);

// Deterministic seed for content variations
const seed = city.slug.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0);

// Schema.org
const faqItems = [
  ...siteConfig.faq.slice(0, 4),
  ...(lc ? [{ q: lc.faq_local.question, a: lc.faq_local.answer }] : []),
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": `${siteConfig.niche.name} à ${city.name}`,
    "description": description,
    "areaServed": {
      "@type": "City",
      "name": city.name,
      "postalCode": city.zip,
    },
    "provider": {
      "@type": "LocalBusiness",
      "name": siteConfig.name,
      "url": `https://www.${siteConfig.domain}/${city.slug}`,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `https://www.${siteConfig.domain}` },
      { "@type": "ListItem", "position": 2, "name": "Annuaire", "item": `https://www.${siteConfig.domain}/annuaire` },
      { "@type": "ListItem", "position": 3, "name": city.name, "item": `https://www.${siteConfig.domain}/${city.slug}` },
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.q.replace('{city}', city.name),
      "acceptedAnswer": { "@type": "Answer", "text": f.a.replace('{city}', city.name) }
    }))
  }
];

// Generic intro fallbacks (ragréage specific)
const genericIntros = [
  `Vous recherchez un artisan pour un **ragréage** à **${city.name}** (${city.zip}) ? Comparez gratuitement jusqu'à 3 devis de professionnels qualifiés dans le département ${city.deptName} (${city.deptCode}). Notre service est 100% gratuit et sans engagement.`,
  `Un **ragréage de sol** à **${city.name}** est indispensable pour obtenir une surface parfaitement plane avant la pose de votre nouveau revêtement. En ${city.region}, les artisans locaux proposent des tarifs compétitifs. Recevez 3 devis gratuits.`,
  `À **${city.name}** (${city.deptName}), de plus en plus de propriétaires font appel à un professionnel pour le **ragréage** de leur sol avant rénovation. Avec des prix allant de 15 à 45 €/m², comparez les devis locaux pour obtenir le meilleur rapport qualité/prix.`,
];

const introText = lc?.intro || genericIntros[seed % genericIntros.length];

// Benefits with deterministic shuffle
const benefits = [
  `Un sol parfaitement **plat et de niveau** à ${city.name}`,
  `Artisans **qualifiés et expérimentés** dans le ${city.deptName} (${city.deptCode})`,
  `Préparation indispensable pour **carrelage ou parquet**`,
  `Produits adaptés : **autolissant ou fibré**`,
  `Séchage rapide pour une **pose accélérée** du revêtement`,
  `Garantie d'une **durabilité maximale** de vos sols`,
];

const shuffledBenefits = [...benefits].sort((a, b) => {
  const ha = a.charCodeAt(seed % a.length);
  const hb = b.charCodeAt(seed % b.length);
  return ha - hb;
});

// Zone climatique
const zoneClimatique = ['H1a', 'H1b', 'H1c', 'H2a', 'H2b', 'H2c', 'H2d', 'H3'];
const zoneIdx = seed % zoneClimatique.length;
const zone = city.region.includes('Hauts-de-France') || city.region.includes('Grand Est') ? 'H1' :
             city.region.includes('PACA') || city.region.includes('Corse') ? 'H3' :
             city.region.includes('Île-de-France') || city.region.includes('Bourgogne') ? 'H1' : 'H2';

// Content sections order (deterministic shuffle)
const sectionOrder = [0, 1, 2, 3, 4].sort((a, b) => {
  return ((a * seed) % 7) - ((b * seed) % 7);
});
---

<BaseLayout
  title={title}
  description={description}
  canonical={`/${city.slug}`}
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="gradient-hero text-white py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: "Annuaire", href: "/annuaire" },
        { label: city.deptName, href: `/departement/${city.deptCode.toLowerCase()}` },
        { label: city.name, href: `/${city.slug}` },
      ]} />

      <div class="grid lg:grid-cols-5 gap-10 items-start mt-6">
        <div class="lg:col-span-3">
          <h1 class="text-2xl md:text-4xl font-extrabold leading-tight mb-6">
            {siteConfig.niche.name} à {city.name} ({city.zip})<br/>
            <span class="text-brand-200 text-xl md:text-2xl font-bold">Prix & Devis Gratuit 2026</span>
          </h1>

          <div class="mb-8">
            <p class="text-gray-300 leading-relaxed" set:html={introText.replace(/\*\*(.*?)\*\*/g, '<strong class="text-white">$1</strong>')} />
          </div>

          <div class="grid sm:grid-cols-2 gap-3 mb-8">
            {shuffledBenefits.map((b) => (
              <div class="flex items-start gap-2 bg-white/5 backdrop-blur-sm rounded-lg px-4 py-3 border border-white/10">
                <span class="text-green-400 mt-0.5">✓</span>
                <span class="text-sm text-gray-200" set:html={b.replace(/\*\*(.*?)\*\*/g, '<strong class="text-white">$1</strong>')} />
              </div>
            ))}
          </div>

          <a href="/devis" class="inline-block bg-accent-500 hover:bg-accent-600 text-dark font-bold px-6 py-3.5 rounded-xl transition-colors shadow-lg text-base">
            {siteConfig.niche.emoji} Comparer 3 Devis à {city.name}
          </a>
        </div>

        <div class="lg:col-span-2" id="devis-form">
          <div class="sticky top-20">
            <QuoteWidget keyword={`${siteConfig.niche.name} ${city.name}`} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content Area -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-10">

    {/* Section: Local Expert Content & EEAT */}
    {lc && (
      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">
          🏠 Réussir son ragréage à {city.name} ({city.deptCode})
        </h2>
        <div class="prose max-w-none text-gray-600 space-y-6">
          <p class="lead">{lc.intro}</p>

          <div class="grid md:grid-cols-2 gap-6 my-6">
            <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-lg">
              <p class="text-blue-900 text-sm" set:html={lc.expert_advice.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')} />
            </div>
            <div class="bg-amber-50 border-l-4 border-amber-500 p-4 rounded-r-lg">
              <p class="text-amber-900 text-sm" set:html={lc.real_estate_context.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')} />
            </div>
          </div>

          <div class="bg-gray-50 border border-gray-200 p-5 rounded-xl">
            <p class="text-gray-700 text-sm" set:html={lc.authority_link_html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')} />
          </div>
        </div>
      </section>
    )}

    {/* Section: Market Data */}
    {lc?.market_data && (
      <section class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-2xl border border-green-200 p-6 md:p-8">
        <h2 class="text-xl font-bold text-gray-900 mb-3">
          📊 Baromètre des prix — {city.deptName} ({city.deptCode})
        </h2>
        <p class="text-gray-700 leading-relaxed">{lc.market_data}</p>
      </section>
    )}

    {/* Section: Generic Local Content (for cities without rich content) */}
    {!lc && (
      <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">
          🏠 Réaliser un ragréage à {city.name}
        </h2>
        <div class="prose max-w-none text-gray-600 space-y-4">
          <p>
            La ville de <strong>{city.name}</strong>, située dans le département <strong>{city.deptName}</strong>
            en région <strong>{city.region}</strong>, compte de nombreux artisans qualifiés
            pour la réalisation de ragréage de sol.
          </p>
          <p>
            Que vous habitiez en centre-ville de {city.name} ou dans les communes environnantes,
            nos artisans partenaires interviennent dans tout le département {city.deptCode}.
            Ils réalisent un diagnostic gratuit de votre sol avant tout devis pour vous proposer
            le type de ragréage le mieux adapté à votre support (autolissant, fibré ou autonivelant).
          </p>
          <p>
            Le prix moyen d'un ragréage dans le {city.deptName} se situe entre
            <strong>15 et 45 €/m²</strong> TTC, fournitures et main d'œuvre comprises.
            Ce tarif varie en fonction de l'état du support existant, de l'épaisseur à rattraper
            et de la classe UPEC requise (P3 pour usage résidentiel standard, P4 pour zones à fort passage).
          </p>
        </div>
      </section>
    )}

    {/* Section: Price Table */}
    <section>
      <p class="text-sm text-gray-500 mb-4">
        💡 Les prix ci-dessous sont des moyennes nationales. À {city.name} ({city.region}),
        les tarifs peuvent varier de ±10% selon
        l'état du support, l'épaisseur à rattraper et le type de ragréage choisi.
      </p>
      <PriceTable />
    </section>

    {/* Section: Detailed Technical Guide for Ragréage (Placeholder if needed, or removed) */}


    {/* Section: Process Steps */}
    <ProcessSteps />

    {/* Section: FAQ (merged generic + local) */}
    {lc ? (
      <FAQ items={[
        ...siteConfig.faq,
        { q: lc.faq_local.question, a: lc.faq_local.answer }
      ]} cityName={city.name} />
    ) : (
      <FAQ items={siteConfig.faq} cityName={city.name} />
    )}

    {/* Section: Nearby Cities */}
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">
        📍 {siteConfig.niche.nameShort} près de {city.name}
      </h2>
      <p class="text-gray-500 text-sm mb-6">Nos artisans interviennent aussi dans ces villes du {city.deptName}</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {nearbyCities.map((nc) => (
          <a
            href={`/${nc.slug}`}
            class="bg-white border border-gray-200 rounded-xl px-4 py-3 hover:border-brand-300 hover:shadow-md transition-all group text-center"
          >
            <span class="font-semibold text-gray-900 group-hover:text-brand-600 text-sm block">{nc.name}</span>
            <span class="text-xs text-gray-400">{nc.zip} • {nc.deptName}</span>
          </a>
        ))}
      </div>
      <div class="text-center mt-4">
        <a href={`/departement/${city.deptCode.toLowerCase()}`} class="text-brand-600 hover:text-brand-700 font-semibold text-sm">
          Voir toutes les villes du {city.deptName} ({city.deptCode}) →
        </a>
      </div>
    </section>

    {/* MAILLAGE: Blog Guides */}
    <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">
        📚 Guides Ragréage — À lire avant vos travaux
      </h2>
      <div class="grid sm:grid-cols-3 gap-4">
        {blogArticles.slice(seed % 2, (seed % 2) + 3).map(a => (
          <a href={`/blog/${a.slug}`} class="bg-gray-50 border border-gray-200 rounded-xl p-4 hover:border-brand-300 hover:shadow-md transition-all group">
            <span class="text-2xl block mb-2">{a.emoji}</span>
            <span class="text-xs text-brand-600 font-medium">{a.category}</span>
            <h3 class="font-semibold text-gray-900 group-hover:text-brand-600 text-sm mt-1 line-clamp-2">{a.title}</h3>
          </a>
        ))}
      </div>
      <div class="text-center mt-4">
        <a href="/blog" class="text-brand-600 hover:text-brand-700 font-semibold text-sm">Voir tous nos guides →</a>
      </div>
    </section>

    {/* Section: Final CTA */}
    <section class="pb-20 md:pb-0">
      <div class="bg-gradient-to-r from-brand-600 to-brand-800 rounded-2xl p-8 text-center text-white">
        <h2 class="text-xl md:text-2xl font-bold mb-3">
          Obtenez vos 3 devis {siteConfig.niche.nameShort} à {city.name}
        </h2>
        <p class="text-brand-100 mb-5 text-sm">
          Gratuit • Sans engagement • Artisans qualifiés du {city.deptName}
        </p>
        <a href="/devis" class="inline-block bg-white text-brand-700 font-bold px-8 py-3.5 rounded-xl hover:bg-brand-50 transition-colors shadow-lg">
          Demander mes devis →
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
